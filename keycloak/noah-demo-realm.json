{
  "realm": "noah-demo",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "noah-demo-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:4000/*"],
      "webOrigins": ["http://localhost:5173", "http://localhost:4000"],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    }
  ],
  "users": [
    {
      "username": "demo@noahcontrols.local",
      "email": "demo@noahcontrols.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "demo1234", "temporary": false }
      ],
      "realmRoles": ["default-roles-noah-demo"]
    }
  ]
}
